APP_NAME=petrichor-agent
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_BASE_URL=http://127.0.0.1:8000
APP_ENABLE_TELEMETRY=true

MODEL_ALIAS=agent.default
MODEL_NAME=qwen3.6:35b-mlx
MODEL_API_BASE=http://127.0.0.1:11434/v1
MODEL_API_KEY=ollama
MODEL_TIMEOUT_SECONDS=120

POSTGRES_DSN=postgresql://postgres:postgres@127.0.0.1:5432/petrichor
POSTGRES_MIN_POOL_SIZE=1
POSTGRES_MAX_POOL_SIZE=10

CLICKHOUSE_ENABLED=true
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8123
CLICKHOUSE_USERNAME=petrichor
CLICKHOUSE_PASSWORD=petrichor
CLICKHOUSE_DATABASE=petrichor

OTEL_SERVICE_NAME=petrichor-agent
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317

PROMPT_SYSTEM_MESSAGE=You are a concise, helpful local agent harness running on a developer workstation.
THREAD_MEMORY_WINDOW=12
SUMMARY_TRIGGER_MESSAGES=12
