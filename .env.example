POSTGRES_MAX_POOL_SIZE=10

CLICKHOUSE_ENABLED=true
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8123
CLICKHOUSE_USERNAME=petrichor
CLICKHOUSE_PASSWORD=petrichor
CLICKHOUSE_DATABASE=petrichor

OTEL_SERVICE_NAME=petrichor-agent
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317

LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-petrichor-agent-dev
LANGFUSE_SECRET_KEY=sk-lf-petrichor-agent-dev
LANGFUSE_BASE_URL=http://127.0.0.1:3000
LANGFUSE_SELF_HOST_URL=http://127.0.0.1:3000
LANGFUSE_SELF_HOST_MINIO_API_URL=http://127.0.0.1:9090
LANGFUSE_NEXTAUTH_SECRET=petrichor-langfuse-nextauth-secret
LANGFUSE_SALT=petrichor-langfuse-salt
LANGFUSE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
LANGFUSE_CLICKHOUSE_USER=clickhouse
LANGFUSE_CLICKHOUSE_PASSWORD=clickhouse
LANGFUSE_MINIO_ROOT_USER=minio
LANGFUSE_MINIO_ROOT_PASSWORD=miniosecret
LANGFUSE_REDIS_AUTH=myredissecret
LANGFUSE_INIT_ORG_ID=petrichor
LANGFUSE_INIT_ORG_NAME=Petrichor
LANGFUSE_INIT_PROJECT_ID=petrichor-agent
LANGFUSE_INIT_PROJECT_NAME=petrichor-agent
